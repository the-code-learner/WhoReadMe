# Copy values into Cloudflare Worker secrets with Wrangler.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=
AUTH_EMAIL_FROM=

# Public origins used by the API Worker.
APP_ORIGIN=http://localhost:4173
API_ORIGIN=http://localhost:8787

# Local-only helper. Leave disabled in deployed environments.
AUTH_DEBUG_LINKS=0
